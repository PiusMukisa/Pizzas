@inherits LayoutComponentBase

<div class="page">
    <header class="app-header">
        <div class="app-brand">
            <img src="/images/logo.svg" alt="Pizza Palace" class="brand-logo" />
            <span>Blazing Pizza</span>
        </div>

        <nav class="top-nav">
            <NavLink href="/" class="top-nav-item" Match="NavLinkMatch.All">
                Home
            </NavLink>
            <NavLink href="/pizzas" class="top-nav-item">
                Get Pizza
            </NavLink>
            <NavLink href="/order" class="top-nav-item">
                My Orders
            </NavLink>
        </nav>
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>

    <footer class="footer">
        <div class="footer-content">
            <p>&copy; 2026 Pizza Palace. All rights reserved.</p>
            <p><strong>Pius Mukisa</strong> | Uganda</p>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
